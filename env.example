# Copy to .env and load in your process, or export these in the shell before `runserver`.
# Same DATABASE_URL and email settings on every host ensure one shared dataset and consistent notifications.

# Django core
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CivicLens admin login at /admin-login/ (not Django superuser)
CIVICLENS_ADMIN_PASSWORD=use-a-long-random-secret

# Database: omit for local SQLite, or use e.g. postgres://user:pass@host:5432/dbname
# DATABASE_URL=sqlite:///db.sqlite3

# Email (resolution notifications). Console backend logs mail in dev.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=CivicLens <no-reply@yourdomain.example>
